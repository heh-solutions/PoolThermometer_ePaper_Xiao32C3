#pragma once

// ---- Netzwerk ----
#define WIFI_HOSTNAME       "PoolThermometer"

// ---- MQTT-Broker ----
#define MQTT_BROKER         "192.168.X.X"
#define MQTT_PORT           18833
#define MQTT_CLIENT         "PoolThermometer"

// ---- MQTT-Topics ----
// Abonnieren (vom ioBroker mqtt.0.PoolLCD.*)
#define TOPIC_VL_TEMP       "PoolLCD/VLTemp"
#define TOPIC_RL_TEMP       "PoolLCD/RLTemp"
// Publizieren
#define TOPIC_POOL_TEMP     "pool/thermometer/pooltemperatur/state"
#define TOPIC_BATTERY       "pool/thermometer/battery/state"
#define TOPIC_STATUS        "pool/thermometer/status"

// ---- KNXnet/IP ----
#define KNX_GATEWAY_IP      "192.168.X.X"
#define KNX_GATEWAY_PORT    3671
#define KNX_PHYS_ADDR       "1.1.165"
#define KNX_GA_POOL_TEMP    "10/3/62"
#define KNX_GA_BATTERY      "12/5/6"

// ---- Deep Sleep ----
#define DEEP_SLEEP_MINUTES  5
